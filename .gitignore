# ════════════════════════════════════════════
#  UniRank — .gitignore
#  Flask + Python + Jupyter data-science project
# ════════════════════════════════════════════

# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual Environment ───────────────────────
venv/
.venv/
env/
.env/
ENV/
pip-wheel-metadata/

# ── Environment / Secrets ─────────────────────
.env
.env.local
.env.production
*.secret
secrets.json

# ── Flask / Production ────────────────────────
instance/
*.cfg
flask_session/

# ── Jupyter Notebooks ─────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Distribution / Build ──────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Testing & Coverage ────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── Type Checking ─────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── IDEs & Editors ────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── OS Generated ──────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Temp / Debug Dumps ────────────────────────
*.json.tmp
oxford.json
debug_*.json
*.log
logs/

# ── Plotly / Static Cache ─────────────────────
static/__pycache__/

# ════════════════════════════════════════════
#  What IS tracked (kept in git):
# ════════════════════════════════════════════
#
#  ✅ app.py                    — Flask application
#  ✅ requirements.txt          — Python dependencies
#  ✅ Dockerfile                — Container build for Hugging Face Spaces
#  ✅ .gitignore                — This file
#  ✅ templates/index.html      — Frontend HTML
#  ✅ static/style.css          — Frontend CSS
#  ✅ static/app.js             — Frontend JavaScript
#  ✅ Cleaned_data--/*.csv      — Cleaned university data (2021-2026)
#  ✅ Result_by_year/*.csv      — MCDM ranking results (2021-2026)
#  ✅ weights/*.json            — Computed criteria weights (2021-2026)
#  ✅ Notebook_code/*.ipynb     — Jupyter analysis notebooks
#
#  ❌ venv/                     — Too large; install via requirements.txt
#  ❌ __pycache__/              — Auto-generated bytecode
#  ❌ .env                      — Never commit secrets
#  ❌ oxford.json               — Temp API debug dump
# ════════════════════════════════════════════
